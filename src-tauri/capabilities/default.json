{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Default permissions required by the VeloMD desktop editor.",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:window:allow-close",
    "core:window:allow-set-title",
    "dialog:allow-message",
    "dialog:allow-open",
    "dialog:allow-save",
    "shell:allow-open"
  ]
}
