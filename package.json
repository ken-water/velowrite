{
  "name": "velowrite",
  "version": "0.1.3",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "launch:video": "node scripts/create-product-hunt-video.mjs",
    "version:sync": "node scripts/sync-version.mjs",
    "release:check": "npm run version:sync -- --check && npm test && npm run build",
    "tauri": "tauri",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build",
    "package:linux": "tauri build --bundles deb,rpm",
    "package:appimage": "tauri build --bundles appimage",
    "package:macos": "tauri build --bundles dmg",
    "package:windows": "tauri build --target x86_64-pc-windows-gnu --bundles nsis"
  },
  "dependencies": {
    "@codemirror/autocomplete": "^6.20.3",
    "@codemirror/commands": "^6.10.4",
    "@codemirror/lang-markdown": "^6.5.0",
    "@codemirror/language": "^6.12.4",
    "@codemirror/search": "^6.7.1",
    "@codemirror/state": "^6.7.1",
    "@codemirror/view": "^6.43.6",
    "@mdit/plugin-katex": "^1.0.1",
    "@tauri-apps/api": "^2.8.0",
    "@tauri-apps/plugin-dialog": "^2.7.1",
    "@vercel/analytics": "^2.0.1",
    "highlight.js": "^11.11.1",
    "katex": "^0.18.0",
    "lucide-react": "^0.468.0",
    "markdown-it": "^14.3.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.8.4",
    "@types/markdown-it": "^14.1.2",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "typescript": "^5.5.4",
    "vite": "^5.4.0",
    "vitest": "^4.1.10"
  }
}
